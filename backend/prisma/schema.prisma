generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoUsuario {
  ADMIN
  FUNCIONARIO
}

enum DiaSemana {
  DOMINGO
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
}

enum FrequenciaChecklist {
  DIARIA
  SEMANAL
  MENSAL
}

enum StatusChecklistExecucao {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDO
  ATRASADO
}

enum StatusTarefaExecucao {
  PENDENTE
  CONCLUIDA
}

model Loja {
  id           Int      @id @default(autoincrement())
  nome         String
  codigo       String   @unique
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  usuarios Usuario[]
  turnos Turno[]
  checklistModelos ChecklistModelo[]
  checklistExecucoes ChecklistExecucao[]
  fotos Foto[]

  @@map("lojas")
}

model Usuario {
  id          Int         @id @default(autoincrement())
  lojaId      Int?        @map("loja_id")
  nome        String
  usuario     String      @unique
  senhaHash   String      @map("senha_hash")
  tipoUsuario TipoUsuario @map("tipo_usuario")
  cargoId     Int?        @map("cargo_id")
  turnoId     Int?        @map("turno_id")
  diaFolga    DiaSemana?  @map("dia_folga")
  ativo       Boolean     @default(true)
  criadoEm    DateTime    @default(now()) @map("criado_em")
  atualizadoEm DateTime   @updatedAt @map("atualizado_em")

  loja Loja? @relation(fields: [lojaId], references: [id])
  cargo Cargo? @relation(fields: [cargoId], references: [id])
  turno Turno? @relation(fields: [turnoId], references: [id])

  checklistModelosEspecificos ChecklistModelo[]
  checklistExecucoes ChecklistExecucao[]
  fotos Foto[]

  @@map("usuarios")
}

model Cargo {
  id           Int      @id @default(autoincrement())
  nome         String   @unique
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  usuarios Usuario[]
  checklistModelos ChecklistModelo[]

  @@map("cargos")
}

model Turno {
  id            Int      @id @default(autoincrement())
  lojaId        Int      @map("loja_id")
  nome          String
  horarioInicio String   @map("horario_inicio")
  horarioFim    String   @map("horario_fim")
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")

  loja Loja @relation(fields: [lojaId], references: [id])
  usuarios Usuario[]
  checklistModelos ChecklistModelo[]

  @@unique([lojaId, nome])
  @@map("turnos")
}

model ChecklistModelo {
  id           Int      @id @default(autoincrement())
  lojaId       Int      @map("loja_id")
  nome         String
  cargoId      Int      @map("cargo_id")
  turnoId      Int?     @map("turno_id")
  usuarioId    Int?     @map("usuario_id")
  frequencia   FrequenciaChecklist @default(DIARIA)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  loja Loja @relation(fields: [lojaId], references: [id])
  cargo Cargo @relation(fields: [cargoId], references: [id])
  turno Turno? @relation(fields: [turnoId], references: [id])
  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  tarefas ChecklistTarefa[]
  execucoes ChecklistExecucao[]

  @@map("checklist_modelos")
}

model ChecklistTarefa {
  id Int @id @default(autoincrement())
  checklistModeloId Int @map("checklist_modelo_id")
  titulo String
  secao String?
  grupo String?
  subgrupo String?
  exigeFoto Boolean @default(false) @map("exige_foto")
  exigeObservacao Boolean @default(false) @map("exige_observacao")
  ordem Int
  criadoEm DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  checklistModelo ChecklistModelo @relation(fields: [checklistModeloId], references: [id], onDelete: Cascade)
  tarefaExecucoes ChecklistTarefaExecucao[]

  @@map("checklist_tarefas")
}

model ChecklistExecucao {
  id Int @id @default(autoincrement())
  lojaId Int @map("loja_id")
  checklistModeloId Int @map("checklist_modelo_id")
  usuarioId Int @map("usuario_id")
  data DateTime
  status StatusChecklistExecucao @default(PENDENTE)
  iniciadoEm DateTime? @map("iniciado_em")
  enviadoEm DateTime? @map("enviado_em")
  codigoConfirmacao String? @map("codigo_confirmacao")
  criadoEm DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  loja Loja @relation(fields: [lojaId], references: [id])
  checklistModelo ChecklistModelo @relation(fields: [checklistModeloId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])
  tarefasExecucoes ChecklistTarefaExecucao[]

  @@unique([checklistModeloId, usuarioId, data])
  @@map("checklist_execucoes")
}

model ChecklistTarefaExecucao {
  id Int @id @default(autoincrement())
  checklistExecucaoId Int @map("checklist_execucao_id")
  checklistTarefaId Int @map("checklist_tarefa_id")
  status StatusTarefaExecucao @default(PENDENTE)
  observacao String?
  concluidoEm DateTime? @map("concluido_em")
  criadoEm DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  checklistExecucao ChecklistExecucao @relation(fields: [checklistExecucaoId], references: [id], onDelete: Cascade)
  checklistTarefa ChecklistTarefa @relation(fields: [checklistTarefaId], references: [id])
  foto Foto?

  @@unique([checklistExecucaoId, checklistTarefaId])
  @@map("checklist_tarefa_execucoes")
}

model Foto {
  id Int @id @default(autoincrement())
  lojaId Int @map("loja_id")
  tarefaExecucaoId Int @unique @map("tarefa_execucao_id")
  usuarioId Int @map("usuario_id")
  url String
  hashArquivo String @unique @map("hash_arquivo")
  criadaEm DateTime @default(now()) @map("criada_em")

  loja Loja @relation(fields: [lojaId], references: [id])
  tarefaExecucao ChecklistTarefaExecucao @relation(fields: [tarefaExecucaoId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("fotos")
}
